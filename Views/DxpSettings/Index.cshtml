@model DxpContentTransfer.Models.SettingsViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>DXP Content Transfer — Settings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 14px;
            line-height: 1.5;
            margin: 0;
            padding: 28px 36px;
            color: #1a1a1a;
            background: #fff;
        }
        h1 { font-size: 22px; font-weight: 600; margin: 0 0 6px; color: #1a1a1a; }
        .subtitle { color: #666; margin: 0 0 24px; font-size: 14px; }
        .alert { padding: 10px 14px; border-radius: 4px; margin-bottom: 18px; font-size: 14px; }
        .alert-success { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; }
        .alert-error   { background: #fdecea; color: #b71c1c; border: 1px solid #ef9a9a; }
        fieldset {
            background: #fafafa;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            padding: 16px 22px 20px;
            margin-bottom: 20px;
        }
        legend {
            font-size: 14px;
            font-weight: 600;
            padding: 0 6px;
            color: #1a1a1a;
        }
        .field { margin-bottom: 14px; }
        .field:last-child { margin-bottom: 0; }
        .field label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            color: #444;
            margin-bottom: 5px;
        }
        .field input {
            width: 100%;
            max-width: 520px;
            padding: 7px 10px;
            border: 1px solid #bbb;
            border-radius: 3px;
            font-size: 14px;
        }
        .field input:focus {
            outline: none;
            border-color: #2973c3;
            box-shadow: 0 0 0 2px rgba(41,115,195,0.2);
        }
        .field-note { display: block; margin-top: 5px; color: #5a6b7b; font-size: 12px; }
        .actions { margin-top: 6px; }
        .btn-save {
            padding: 9px 24px;
            background: #2973c3;
            color: #fff;
            border: none;
            border-radius: 3px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            letter-spacing: 0.01em;
        }
        .btn-save:hover { background: #1f5ea3; }
        .field-test {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 14px;
            flex-wrap: wrap;
        }
        .btn-test {
            padding: 6px 16px;
            background: #fff;
            color: #2973c3;
            border: 1px solid #2973c3;
            border-radius: 3px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
        }
        .btn-test:hover { background: #f0f6fc; }
        .btn-test:disabled { opacity: 0.6; cursor: default; }
        .test-result { font-size: 13px; }
        .test-result.pending { color: #5a6b7b; }
        .test-result.ok      { color: #1b5e20; }
        .test-result.fail    { color: #b71c1c; }
        .help {
            background: #f0f6fc;
            border: 1px solid #c3dbf0;
            border-radius: 6px;
            padding: 16px 22px 18px;
            margin-bottom: 24px;
            max-width: 760px;
        }
        .help h2 {
            font-size: 15px;
            font-weight: 600;
            margin: 0 0 6px;
            color: #1a1a1a;
        }
        .help p { margin: 0 0 12px; color: #33475b; }
        .help ol { margin: 0 0 4px; padding-left: 22px; }
        .help li { margin-bottom: 9px; color: #33475b; }
        .help li:last-child { margin-bottom: 0; }
        .help code {
            background: #e4eef8;
            border-radius: 3px;
            padding: 1px 5px;
            font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 12.5px;
            color: #11385c;
        }
        .help .note {
            margin: 12px 0 0;
            font-size: 13px;
            color: #5a6b7b;
        }
        .help-shot {
            display: block;
            width: 100%;
            max-width: 720px;
            height: auto;
            margin: 12px 0 2px;
            border: 1px solid #c3dbf0;
            border-radius: 5px;
            box-shadow: 0 1px 3px rgba(17,56,92,0.08);
        }
    </style>
</head>
<body>
    <h1>DXP Content Transfer Settings</h1>
    <p class="subtitle">Enter the OpenID Connect API credentials for each environment you want to transfer content to or from.</p>

    <div class="help">
        <h2>Where do I find the Client Key and Secret?</h2>
        <p>
            The gadget reads and writes content over the Optimizely Content Management and Content Delivery
            APIs, authenticating with the OAuth2 <strong>client&nbsp;credentials</strong> flow. Each environment
            therefore needs an OpenID&nbsp;Connect API client (an <em>application</em>) registered <strong>on that
            environment</strong>, granted the content-management scope. The Key and Secret below are that
            application's credentials.
        </p>
        <ol>
            <li>
                <strong>Base URL</strong> — the public address of the environment, e.g.
                <code>https://&lt;name&gt;inte.dxcloud.episerver.net</code> (Integration),
                the Preproduction/Production host, or <code>https://localhost:5000</code> for a local site.
            </li>
            <li>
                On that environment's site, register an OpenID&nbsp;Connect application for the
                <code>client_credentials</code> grant. The quickest way is in that environment's CMS admin UI:
                <strong>Settings&nbsp;&rarr; <a href="/EPiServer/EPiServer.OpenIDConnect.UI/Default/#/oidc/applications" target="_top">OpenID&nbsp;Connect</a> &rarr; Applications &rarr; Create&nbsp;New&nbsp;Application</strong>
                &mdash; create a <em>Confidential</em> client, which gives you a <code>Client&nbsp;id</code> and a
                generated secret. (Equivalently, applications can be declared in the host's configuration,
                typically <code>appsettings.json</code> under <code>OpenIDConnect:Applications</code>, surfaced
                through <code>services.AddOpenIDConnect&lt;&gt;()</code>.) Whichever route you use, include the scope
                <code>epi_content_management</code> &mdash; without it every request returns 403.
                <img class="help-shot" src="data:image/png;base64,"
                     alt="OpenID Connect Applications panel in the Optimizely CMS admin UI, showing the Create New Application button and a Confidential client named dxp-content-transfer-dev" />
            </li>
            <li>
                Copy that application's <code>ClientId</code> into <strong>Client Key (client_id)</strong> here.
            </li>
            <li>
                Copy the matching <code>ClientSecret</code> into <strong>Client Secret</strong> here.
            </li>
            <li>
                Repeat for each environment you intend to use, then click <strong>Save Settings</strong>.
            </li>
            <li>
                You will also have to give the Open ID account you have created, full read and write permissions for the pages that you want to transfer. This is done in the CMS admin UI, under <strong><a href="/EPiServer/EPiServer.Cms.UI.Admin/default#/AccessRights/SetAccessRights" target="_top">Admin &gt; Access Rights</a></strong>. You can create a new role for this purpose, and assign it to the Open ID account.
            </li>
        </ol>
        <p class="note">
            Note: the environment the gadget runs on needs a client too — it reads its own <em>source</em>
            content over the same APIs. Saved credentials are pre-filled when you reopen this page, and
            <strong>Save&nbsp;Settings</strong> stores exactly what each field contains — so clearing a Secret
            field and saving will erase the stored value.
        </p>
    </div>

    @if (Model.Saved)
    {
        <div class="alert alert-success">Settings saved successfully.</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post" action="/EPiServer/DxpContentTransfer/Admin/Settings">
        @Html.AntiForgeryToken()

        <fieldset>
            <legend>Integration</legend>
            <div class="field">
                <label for="IntegrationBaseUrl">Base URL</label>
                <input type="url" id="IntegrationBaseUrl" name="IntegrationBaseUrl"
                       value="@Model.IntegrationBaseUrl" placeholder="https://integration.example.com" />
            </div>
            <div class="field">
                <label for="IntegrationClientKey">Client Key (client_id)</label>
                <input type="text" id="IntegrationClientKey" name="IntegrationClientKey"
                       value="@Model.IntegrationClientKey" placeholder="client_id" autocomplete="off" />
            </div>
            <div class="field">
                <label for="IntegrationClientSecret">Client Secret</label>
                <input type="password" id="IntegrationClientSecret" name="IntegrationClientSecret"
                       value="@Model.IntegrationClientSecret" autocomplete="new-password" />
            </div>
            <div class="field">
                <label for="IntegrationLabel">Display label (optional)</label>
                <input type="text" id="IntegrationLabel" name="IntegrationLabel" value="@Model.IntegrationLabel" placeholder="Integration" maxlength="24" />
                <small class="field-note">Shown in the transfer gadget instead of &ldquo;Integration&rdquo;. Leave blank to use the default name.</small>
            </div>
            <div class="field-test">
                <button type="button" class="btn-test" data-env="Integration">Test connection</button>
                <span class="test-result" data-env="Integration" aria-live="polite"></span>
            </div>
        </fieldset>

        <fieldset>
            <legend>Preproduction</legend>
            <div class="field">
                <label for="PreproductionBaseUrl">Base URL</label>
                <input type="url" id="PreproductionBaseUrl" name="PreproductionBaseUrl"
                       value="@Model.PreproductionBaseUrl" placeholder="https://preproduction.example.com" />
            </div>
            <div class="field">
                <label for="PreproductionClientKey">Client Key (client_id)</label>
                <input type="text" id="PreproductionClientKey" name="PreproductionClientKey"
                       value="@Model.PreproductionClientKey" placeholder="client_id" autocomplete="off" />
            </div>
            <div class="field">
                <label for="PreproductionClientSecret">Client Secret</label>
                <input type="password" id="PreproductionClientSecret" name="PreproductionClientSecret"
                       value="@Model.PreproductionClientSecret" autocomplete="new-password" />
            </div>
            <div class="field">
                <label for="PreproductionLabel">Display label (optional)</label>
                <input type="text" id="PreproductionLabel" name="PreproductionLabel" value="@Model.PreproductionLabel" placeholder="Preproduction" maxlength="24" />
                <small class="field-note">Shown in the transfer gadget instead of &ldquo;Preproduction&rdquo;. Leave blank to use the default name.</small>
            </div>
            <div class="field-test">
                <button type="button" class="btn-test" data-env="Preproduction">Test connection</button>
                <span class="test-result" data-env="Preproduction" aria-live="polite"></span>
            </div>
        </fieldset>

        <fieldset>
            <legend>Production</legend>
            <div class="field">
                <label for="ProductionBaseUrl">Base URL</label>
                <input type="url" id="ProductionBaseUrl" name="ProductionBaseUrl"
                       value="@Model.ProductionBaseUrl" placeholder="https://www.example.com" />
            </div>
            <div class="field">
                <label for="ProductionClientKey">Client Key (client_id)</label>
                <input type="text" id="ProductionClientKey" name="ProductionClientKey"
                       value="@Model.ProductionClientKey" placeholder="client_id" autocomplete="off" />
            </div>
            <div class="field">
                <label for="ProductionClientSecret">Client Secret</label>
                <input type="password" id="ProductionClientSecret" name="ProductionClientSecret"
                       value="@Model.ProductionClientSecret" autocomplete="new-password" />
            </div>
            <div class="field">
                <label for="ProductionLabel">Display label (optional)</label>
                <input type="text" id="ProductionLabel" name="ProductionLabel" value="@Model.ProductionLabel" placeholder="Production" maxlength="24" />
                <small class="field-note">Shown in the transfer gadget instead of &ldquo;Production&rdquo;. Leave blank to use the default name.</small>
            </div>
            <div class="field-test">
                <button type="button" class="btn-test" data-env="Production">Test connection</button>
                <span class="test-result" data-env="Production" aria-live="polite"></span>
            </div>
        </fieldset>

        <div class="actions">
            <button type="submit" class="btn-save">Save Settings</button>
        </div>

    </form>

    <script>
        (function () {
            var token = function () {
                var el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            };

            function val(id) {
                var el = document.getElementById(id);
                return el ? el.value.trim() : '';
            }

            function runTest(env, button, result) {
                var baseUrl = val(env + 'BaseUrl');
                var clientKey = val(env + 'ClientKey');
                var clientSecret = val(env + 'ClientSecret');

                if (!baseUrl || !clientKey || !clientSecret) {
                    result.className = 'test-result fail';
                    result.textContent = 'Enter Base URL, Client Key and Client Secret first.';
                    return;
                }

                button.disabled = true;
                result.className = 'test-result pending';
                result.textContent = 'Testing…';

                var body = new URLSearchParams();
                body.append('environment', env);
                body.append('baseUrl', baseUrl);
                body.append('clientKey', clientKey);
                body.append('clientSecret', clientSecret);
                body.append('__RequestVerificationToken', token());

                fetch('/EPiServer/DxpContentTransfer/Admin/TestConnection', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                })
                .then(function (r) {
                    if (!r.ok) throw new Error('Request failed (' + r.status + ')');
                    return r.json();
                })
                .then(function (data) {
                    result.className = 'test-result ' + (data.ok ? 'ok' : 'fail');
                    result.textContent = (data.ok ? '✓ ' : '✗ ') + data.message;
                })
                .catch(function (err) {
                    result.className = 'test-result fail';
                    result.textContent = '✗ Could not run the test: ' + err.message;
                })
                .finally(function () { button.disabled = false; });
            }

            document.querySelectorAll('.btn-test').forEach(function (button) {
                button.addEventListener('click', function () {
                    var env = button.getAttribute('data-env');
                    var result = document.querySelector('.test-result[data-env="' + env + '"]');
                    runTest(env, button, result);
                });
            });
        })();
    </script>
</body>
</html>
