@model DxpContentTransfer.Models.SettingsViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>DXP Content Transfer — Settings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 14px;
            line-height: 1.5;
            margin: 0;
            padding: 28px 36px;
            color: #1a1a1a;
            background: #fff;
        }
        h1 { font-size: 22px; font-weight: 600; margin: 0 0 6px; color: #1a1a1a; }
        .subtitle { color: #666; margin: 0 0 24px; font-size: 14px; }
        .alert { padding: 10px 14px; border-radius: 4px; margin-bottom: 18px; font-size: 14px; }
        .alert-success { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; }
        .alert-error   { background: #fdecea; color: #b71c1c; border: 1px solid #ef9a9a; }
        fieldset {
            background: #fafafa;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            padding: 16px 22px 20px;
            margin-bottom: 20px;
        }
        legend {
            font-size: 14px;
            font-weight: 600;
            padding: 0 6px;
            color: #1a1a1a;
        }
        .field { margin-bottom: 14px; }
        .field:last-child { margin-bottom: 0; }
        .field label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            color: #444;
            margin-bottom: 5px;
        }
        .field input {
            width: 100%;
            max-width: 520px;
            padding: 7px 10px;
            border: 1px solid #bbb;
            border-radius: 3px;
            font-size: 14px;
        }
        .field input:focus {
            outline: none;
            border-color: #2973c3;
            box-shadow: 0 0 0 2px rgba(41,115,195,0.2);
        }
        .actions { margin-top: 6px; }
        .btn-save {
            padding: 9px 24px;
            background: #2973c3;
            color: #fff;
            border: none;
            border-radius: 3px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            letter-spacing: 0.01em;
        }
        .btn-save:hover { background: #1f5ea3; }
    </style>
</head>
<body>
    <h1>DXP Content Transfer Settings</h1>
    <p class="subtitle">Configure OAuth2 client credentials for each DXP environment. These are used to obtain bearer tokens for the Content Management API. Details for creating Keys and Secrets can be found on <a href="https://docs.developers.optimizely.com/digital-experience-platform/v1.3.0-DXP-for-CMS11-COM13/docs/authentication" target="_blank">Optimizely's API Authentication Page.</a></p>

    @if (Model.Saved)
    {
        <div class="alert alert-success">Settings saved successfully.</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post" action="/EPiServer/DxpContentTransfer/Admin/Settings">
        @Html.AntiForgeryToken()

        <fieldset>
            <legend>Integration</legend>
            <div class="field">
                <label for="IntegrationBaseUrl">Base URL</label>
                <input type="url" id="IntegrationBaseUrl" name="IntegrationBaseUrl"
                       value="@Model.IntegrationBaseUrl" placeholder="https://integration.example.com" />
            </div>
            <div class="field">
                <label for="IntegrationClientKey">Client Key (client_id)</label>
                <input type="text" id="IntegrationClientKey" name="IntegrationClientKey"
                       value="@Model.IntegrationClientKey" placeholder="client_id" autocomplete="off" />
            </div>
            <div class="field">
                <label for="IntegrationClientSecret">Client Secret</label>
                <input type="password" id="IntegrationClientSecret" name="IntegrationClientSecret"
                       value="@Model.IntegrationClientSecret" autocomplete="new-password" />
            </div>
        </fieldset>

        <fieldset>
            <legend>Preproduction</legend>
            <div class="field">
                <label for="PreproductionBaseUrl">Base URL</label>
                <input type="url" id="PreproductionBaseUrl" name="PreproductionBaseUrl"
                       value="@Model.PreproductionBaseUrl" placeholder="https://preproduction.example.com" />
            </div>
            <div class="field">
                <label for="PreproductionClientKey">Client Key (client_id)</label>
                <input type="text" id="PreproductionClientKey" name="PreproductionClientKey"
                       value="@Model.PreproductionClientKey" placeholder="client_id" autocomplete="off" />
            </div>
            <div class="field">
                <label for="PreproductionClientSecret">Client Secret</label>
                <input type="password" id="PreproductionClientSecret" name="PreproductionClientSecret"
                       value="@Model.PreproductionClientSecret" autocomplete="new-password" />
            </div>
        </fieldset>

        <fieldset>
            <legend>Production</legend>
            <div class="field">
                <label for="ProductionBaseUrl">Base URL</label>
                <input type="url" id="ProductionBaseUrl" name="ProductionBaseUrl"
                       value="@Model.ProductionBaseUrl" placeholder="https://www.example.com" />
            </div>
            <div class="field">
                <label for="ProductionClientKey">Client Key (client_id)</label>
                <input type="text" id="ProductionClientKey" name="ProductionClientKey"
                       value="@Model.ProductionClientKey" placeholder="client_id" autocomplete="off" />
            </div>
            <div class="field">
                <label for="ProductionClientSecret">Client Secret</label>
                <input type="password" id="ProductionClientSecret" name="ProductionClientSecret"
                       value="@Model.ProductionClientSecret" autocomplete="new-password" />
            </div>
        </fieldset>

        <div class="actions">
            <button type="submit" class="btn-save">Save Settings</button>
        </div>

        

    </form>
</body>
</html>
